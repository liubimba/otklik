{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Otklik",
	"mainBinaryName": "otklik",
	"version": "0.2.1",
	"identifier": "ai.otklik.app",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../build"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"label": "main",
				"title": "Otklik",
				"width": 800,
				"height": 600,
				"minWidth": 720,
				"minHeight": 560,
				"devtools": true,
				"decorations": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"updater": {
			"endpoints": [
				"https://github.com/liubimba/otklik/releases/latest/download/latest.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBNzU3MjAxRjAxRkU0NTcKUldSWDVCL3dBWEoxaXJTUjVkQzFPakxWdTBRcDF6cDlUb2VZbGEwdnhZM3NkMjlsSVVEdURDbVUK",
			"windows": {
				"installMode": "passive"
			}
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": ["resources/backend/**/*"]
	}
}
